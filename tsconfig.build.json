{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "outDir": "dist",
    "rootDir": "src",
    "noEmit": false,
    "types": ["react", "react-dom"]
  },
  "include": ["src"],
  "exclude": ["tests", "stories", "src/**/*.test.ts", "src/**/*.test.tsx", "src/**/*.stories.tsx"]
}
